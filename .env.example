# Application
APP_NAME=Integraty
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true

# Server
HOST=localhost
PORT=8080

# Database
DATABASE_URL=sqlite:///./data/database/integraty.db

# Security
SECRET_KEY=change-this-secret-key-in-production
JWT_SECRET=change-this-jwt-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Monitoring
SCREENSHOT_INTERVAL=30
SCREENSHOT_QUALITY=85

# OCR
OCR_ENABLED=true
TESSERACT_PATH=

# Logging
LOG_LEVEL=INFO
